GHL_API_TOKEN=
GHL_LOCATION_ID=
PIPELINE_ID=
ATTEMPTING_CONTACT_STAGE_ID=

# Existing GoHighLevel workflow that contains the Manual Call step.
# The sync enrolls contacts by API; it does not require a native "Contact Added to Workflow" trigger.
# When set, contacts are enrolled here so they enter the power dialer/manual call queue.
# If empty, the sync falls back to creating a call task.
DIALER_WORKFLOW_ID=

# Used for persistent once-per-day duplicate prevention.
# The sync applies a daily tag like dialer_added_today_2026-04-28 after queueing.
DIALER_DEDUPE_TAG_PREFIX=dialer_added_today

# Optional task-mode settings.
GHL_TASK_TITLE=Manual call - Attempting Contact
GHL_TASK_BODY=Queued from Attempting Contact deal board stage.
GHL_TASK_DUE_MINUTES=0
GHL_TASK_ASSIGNED_TO=

# Scheduler settings.
LOCAL_TIMEZONE=America/Indiana/Indianapolis
SCHEDULE_TIMES=10:00,13:00,17:00
RUN_ON_START=false

# API tuning.
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2023-02-21
GHL_PAGE_LIMIT=100
